# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Large data (use DVC or external storage) ──────────────────────────────────
data/images/
data/raw/
checkpoints/
training/data/

# ── Evaluation outputs (keep summaries, ignore raw results) ───────────────────
evaluation/results/
!evaluation/results/.gitkeep

# ── Python build artifacts ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Logs (generated at runtime by logger.py) ──────────────────────────────────
logs/
*.log

# ── MLflow ────────────────────────────────────────────────────────────────────
.mlflow/
mlruns/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Model weights (track via MLflow, not Git) ─────────────────────────────────
*.pt
*.bin
*.safetensors
*.gguf