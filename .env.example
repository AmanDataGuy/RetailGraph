# ════════════════════════════════════════════════════════════════
#  RetailGraph — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to Git.
# ════════════════════════════════════════════════════════════════

# ── Neo4j ────────────────────────────────────────────────────────
# Local:      bolt://localhost:7687
# AuraDB:     neo4j+s://xxxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# ── OpenAI ───────────────────────────────────────────────────────
# Used only for seeding 3k GPT-4o-mini training pairs (Phase 1)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Kafka ────────────────────────────────────────────────────────
# Docker default is localhost:9092
# Multiple brokers: "broker1:9092,broker2:9092"
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RAW_TOPIC=product.raw
KAFKA_EXTRACTED_TOPIC=product.extracted
KAFKA_FAILED_TOPIC=product.failed

# ── Redis ────────────────────────────────────────────────────────
# Used for API rate limiting
REDIS_URL=redis://localhost:6379

# ── MLflow ───────────────────────────────────────────────────────
# Tracks every training run + model version
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=retailgraph-extraction

# ── API ──────────────────────────────────────────────────────────
# API_KEY is what clients send in headers to authenticate requests
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_api_key_here
API_HOST=0.0.0.0
API_PORT=8000

# ── Extraction ───────────────────────────────────────────────────
MAX_RETRIES=3
CONFIDENCE_THRESHOLD=0.85
BATCH_SIZE=32

# ── Domain ───────────────────────────────────────────────────────
# Controls which YAML adapter the pipeline loads
# Options: retail | healthcare | b2b
DOMAIN_ADAPTER=retail